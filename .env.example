# ============================================================
# Job Crawler Configuration
# Copy this to .env and fill in your values
# ============================================================

# --- Target Criteria ---
TARGET_ROLES=Backend Engineer,Data Engineer,Platform Engineer
SENIORITY=Mid,Senior
LOCATIONS=Remote,Bangalore,Chennai
INCLUDE_KEYWORDS=Python,AWS,distributed systems,Kubernetes,Go,microservices
EXCLUDE_KEYWORDS=unpaid,internship,clearance required,security clearance,TS/SCI
MIN_MATCH_SCORE=0.7

# --- Resume ---
# Supports .txt, .pdf, .docx
RESUME_PATH=./resume.txt

# --- AI Embeddings ---
# Provider: "openai", "gemini", or "keyword" (no API key needed)
EMBEDDING_PROVIDER=openai
EMBEDDING_API_KEY=sk-your-openai-key-here
# OpenAI model (if provider=openai): text-embedding-3-small, text-embedding-3-large
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# Gemini model (if provider=gemini): text-embedding-004
GEMINI_EMBEDDING_MODEL=text-embedding-004

# --- Tier 1: Company Slugs (comma-separated) ---
# Adding a company = just add its slug here. One-line change.
GREENHOUSE_COMPANIES=stripe,gitlab,cloudflare,figma,datadog,twilio,airbnb,coinbase,discord
LEVER_COMPANIES=hashicorp,vercel,notion,netlify,tailscale
ASHBY_COMPANIES=ramp,linear,anthropic

# --- Tier 2: Aggregator Feeds ---
ENABLE_REMOTEOK=true
ENABLE_WEWORKREMOTELY=true
ENABLE_HACKERNEWS=true
ENABLE_ARBEITNOW=true

# --- Tier 3: Custom Career Pages ---
# JSON list: [{"slug": "company", "url": "...", "selector": "...", "js_render": false}]
CAREER_PAGES_JSON=[]

# --- Tier 4: Manual Search URLs (LinkedIn, Indeed, Glassdoor) ---
# These are auto-generated and printed/emailed — never scraped.
GENERATE_MANUAL_URLS=true

# --- Email Notification (SMTP) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USER=your@gmail.com
SMTP_PASSWORD=your-app-password
NOTIFY_FROM=your@gmail.com
NOTIFY_TO=your@gmail.com

# --- Compliance ---
USER_AGENT=JobCrawler/1.0 (contact: your@email.com)
RATE_LIMIT_PER_SECOND=1.0
REQUEST_TIMEOUT=30

# --- Schedule ---
CRAWL_INTERVAL_HOURS=4

# --- Database ---
DB_PATH=./data/jobs.db
